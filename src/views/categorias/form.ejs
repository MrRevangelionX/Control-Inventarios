<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/navbar') %>

  <main class="container container-narrow">
    <h1><%= categoria ? 'Editar categoria' : 'Nueva categoria' %></h1>

    <form
      class="form"
      method="POST"
      action="<%= categoria ? `/categorias/${categoria.id}?_method=PUT` : '/categorias' %>"
    >
      <div class="form-group">
        <label for="nombre">Nombre *</label>
        <input
          type="text"
          id="nombre"
          name="nombre"
          value="<%= categoria ? categoria.nombre : '' %>"
          required
          maxlength="100"
        >
      </div>

      <div class="form-group">
        <label for="descripcion">Descripcion</label>
        <textarea id="descripcion" name="descripcion" rows="3" maxlength="255"><%= categoria ? (categoria.descripcion || '') : '' %></textarea>
      </div>

      <div class="form-actions">
        <a class="btn btn-secondary" href="/categorias">Cancelar</a>
        <button type="submit" class="btn btn-primary">Guardar</button>
      </div>
    </form>
  </main>

  <%- include('../partials/alerts') %>
</body>
</html>
